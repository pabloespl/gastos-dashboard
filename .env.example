# Google OAuth (login en la webapp)
GOOGLE_OAUTH_CLIENT_ID=         # Client ID de la app OAuth: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
GOOGLE_OAUTH_CLIENT_SECRET=     # Client Secret de la misma app OAuth (nunca exponer en frontend, solo usar en servidor)

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=    # JSON completo de la Service Account (solo producción y GitHub Actions). En local usa google-service-account.json
GOOGLE_SHEET_ID=                # ID del Google Sheet extraído de la URL: docs.google.com/spreadsheets/d/<ID>/edit

# Anthropic
ANTHROPIC_API_KEY=              # API key de console.anthropic.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=       # URL del proyecto: Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # Anon key pública: Settings > API > Project API keys > anon public
SUPABASE_SERVICE_KEY=           # Service role key: Settings > API > Project API keys > service_role (solo GitHub Actions, nunca exponer en frontend)

# ntfy
NTFY_TOPIC=                     # Nombre de tu canal privado en ntfy.sh (ej: mis-gastos-abc123)

# App
NEXT_PUBLIC_ALLOWED_EMAIL=      # Tu email de Google para restringir acceso al dashboard (debe coincidir con el email en las RLS policies de Supabase)
